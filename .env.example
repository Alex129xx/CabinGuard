# Copy this file to .env and provide the values from the corresponding dashboards.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Keep false unless the WSL environment has a working HTTP/SOCKS proxy.
DEEPSEEK_USE_ENV_PROXY=false
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_CODE=
AMAP_WEB_SERVICE_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=
